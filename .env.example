# ── Supabase (obrigatório) ───────────────────────────────────────────────
# Painel Supabase › Project Settings › API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — NUNCA expor no client. Usada em sync, cron e Storage.
SUPABASE_SERVICE_ROLE_KEY=

# Conexão direta ao Postgres (só para `npm run db:apply`). Opcional.
# SUPABASE_DB_URL=postgresql://postgres:SENHA@db.<ref>.supabase.co:5432/postgres

# ── Cron / sync ──────────────────────────────────────────────────────────
# Segredo do endpoint /api/cron/marketing-sync (Vercel Cron manda no header).
CRON_SECRET=

# ── Integrações (opcionais — deixe vazio até ativar) ─────────────────────
# Meta Ads / Instagram Graph
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# Google Ads
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=

# GA4
GA4_PROPERTY_ID=
